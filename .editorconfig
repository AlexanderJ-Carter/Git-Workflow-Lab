# EditorConfig - 统一编辑器配置
# https://editorconfig.org

root = true

# 所有文件的默认配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Python 文件
[*.py]
indent_size = 4

# YAML 文件
[*.{yml,yaml}]
indent_size = 2

# JSON 文件
[*.json]
indent_size = 2

# Shell 脚本
[*.sh]
end_of_line = lf

# Makefile
[Makefile]
indent_style = tab
