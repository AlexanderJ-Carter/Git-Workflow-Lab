# ============================================
# Git Workflow Lab - 环境变量配置
# ============================================
# 重要提示：
# 1. 复制此文件为 .env 并修改所有密码和密钥
# 2. 所有标记为 REQUIRED 的变量必须设置
# 3. 不要将 .env 文件提交到版本控制
# ============================================

# ============================================
# 数据库配置 [REQUIRED]
# ============================================
# PostgreSQL 数据库密码 - 请使用强密码（至少 16 位随机字符）
# 生成方法: openssl rand -base64 24
GITEA_DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ============================================
# Gitea 管理员配置 [REQUIRED]
# ============================================
# 管理员用户名
GITEA_ADMIN_USER=playground

# 管理员密码 - 请使用强密码（至少 12 位，包含字母数字符号）
GITEA_ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# 管理员邮箱
GITEA_ADMIN_EMAIL=playground@example.com

# ============================================
# Gitea 安全配置 [REQUIRED]
# ============================================
# 安全密钥 - 用于加密会话等敏感数据
# 生成方法: openssl rand -base64 32
GITEA_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_STRING

# ============================================
# 服务 URL 配置
# ============================================
# Gitea 公开访问 URL
PUBLIC_GITEA_URL=http://localhost:3000/

# 文档站点来源（用于 iframe 嵌入）
PUBLIC_DOCS_ORIGIN=http://localhost:8081

# Gitea 域名配置
GITEA_DOMAIN=localhost
GITEA_SSH_DOMAIN=localhost
GITEA_SSH_PORT=2222
